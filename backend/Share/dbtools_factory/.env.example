# Copy this file to .env and fill in real values.
# Note: .env should NOT be committed to git.

# --- Django internal DB (admin/auth/session) ---
DB__DJANGO__TYPE=sqlite
# Linux/mac absolute path example:
# DB__DJANGO__URL=sqlite:////absolute/path/to/db.sqlite3
# Windows example:
# DB__DJANGO__URL=sqlite:///D:/Projects/backend/db.sqlite3
# Relative path example (relative to working directory):
DB__DJANGO__URL=sqlite:///./db.sqlite3

# --- Your primary relational DB for business data (optional) ---
DB__DEFAULT__TYPE=postgres
DB__DEFAULT__URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME

# --- Mongo for documents/analytics (optional) ---
DB__MONGO__TYPE=mongo
DB__MONGO__URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?appName=Cluster0
DB__MONGO__DB=analytics
